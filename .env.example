# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Cryptography
# Generate with: aem keygen
AEM_PRIVATE_KEY=
AEM_PUBLIC_KEY=

# Solver Settings
SOLVER_MIN_REPUTATION=0.5
SOLVER_TIMEOUT_MS=30000
BID_WINDOW_MS=10000

# Market Settings
PLATFORM_FEE_PERCENT=1
MIN_INTENT_FEE=10

# Clearinghouse Endpoint (for CLI)
AEM_ENDPOINT=http://localhost:3000
